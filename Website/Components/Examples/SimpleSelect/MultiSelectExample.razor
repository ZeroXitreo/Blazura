@using System.ComponentModel.DataAnnotations

<VStack>
    Currently selected options: @string.Join(", ", selectedOptions)
    <InputMultiSelect @bind-Value="selectedOptions" Options="options.Order()" />
</VStack>

@code {
    private List<string> options = ["Apple", "Banana", "Cherry", "Date", "Fig", "Guava", "Kiwi", "Mango", "Pear", "Raspberry",
    "Apple2", "Banana2", "Cherry2", "Date2", "Fig2", "Guava2", "Kiwi2", "Mango2", "Pear2", "Raspberry2"];

    [Display(Name = "Selected options")]
    private List<string> selectedOptions = ["Apple", "Orange"];
}