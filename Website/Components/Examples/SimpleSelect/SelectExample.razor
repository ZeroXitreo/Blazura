@using System.ComponentModel.DataAnnotations

<VStack>
    Currently selected options: @string.Join(", ", selectedOptions)
    <InputSingleSelect @bind-Value="selectedOptions" Options="options" />
</VStack>

@code {
    private List<string> options = ["Apple", "Banana"];

    [Display(Name = "Selected options")]
    private string? selectedOptions = "Orange";
}