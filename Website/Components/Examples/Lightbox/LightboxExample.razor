<SimpleButton OnClick="OpenLightbox">Open lightbox</SimpleButton>

@code {
    [CascadingParameter]
    private Lightbox lightbox { get; set; } = default!;

    private List<File> files = [
        new() {
            Path = "/images/img1.jpg"
        },
        new() {
            Path = "/images/img2.jpg"
        },
        new() {
            Path = "/images/img3.png"
        },
    ];

    private void OpenLightbox()
    {
        lightbox.Open(files.First(), files);
    }

    private class File : IPath
    {
        public required string Path { get; init; }
    }
}
