@inject IWebHostEnvironment env

<Paper>
    <Pad>
        <VStack>
            <DynamicComponent Type="Type" />
            <HStack StackBehaviour="StackBehaviour.Left">
                <StackWeight Weight="null">
                    <SimpleButton @onclick="() => showCodeBlock = !showCodeBlock" Style="@(showCodeBlock ? Style.Normal : Style.Outline)">@(showCodeBlock ? "Hide" : "Show") Code</SimpleButton>
                </StackWeight>
            </HStack>
            @if (showCodeBlock)
            {
                <CodeBlock>@(GetCodeBlock())</CodeBlock>
            }
        </VStack>
    </Pad>
</Paper>

@code {
    [Parameter, EditorRequired]
    public string Folder { get; set; }

    [Parameter, EditorRequired]
    public Type Type { get; set; }

    private string GetCodeBlock() => File.ReadAllText(Path.Combine(env.ContentRootPath, "Components", "Examples", Folder, $"{Type.Name}.razor"));

    private bool showCodeBlock;
}
