@using Microsoft.AspNetCore.Components.Forms
@using System.ComponentModel
@using Blazura.Components.ColumnWrapperItems
@using System.ComponentModel.DataAnnotations
@typeparam T

<Modal2 @ref="modal">
    @if (Item is null)
    {
        return;
    }

    <VStack>
        <h1>Confirm deletion</h1>
        <div class="DeleteModal">
            <VStack>
                @if (ChildContent is not null)
                {
                    @ChildContent
                }
                else
                {
                    <div>
                        Are you sure you want to do this?
                    </div>
                }
                @{
                    string? prompt = null;
                    if (Prompt is not null)
                    {
                        var proposedPrompt = Prompt(Item);
                        if (!string.IsNullOrWhiteSpace(Prompt(Item)))
                        {
                            prompt = proposedPrompt;
                        }
                    }
                }
                @if (prompt is not null)
                {
                    <div>
                        To confirm, please write <code>@prompt</code> below
                    </div>
                    <div>
                        <Placeholder For="() => promptResponse">
                            <input @bind="promptResponse" @bind:event="oninput" />
                        </Placeholder>
                    </div>
                }
                <HStack>
                    <StackWeight>
                        <SimpleButton Style="Style.Outline" @onclick="modal.Close">Cancel</SimpleButton>
                    </StackWeight>
                    <StackWeight Weight="2">
                        <SimpleButton Color="Color.Error" Type="ButtonType.Button" @onclick="Submit" Disabled="@(prompt is not null ? prompt != promptResponse : false)">Confirm</SimpleButton>
                    </StackWeight>
                </HStack>
            </VStack>
        </div>
    </VStack>
</Modal2>

@code {

    [Parameter]
    public Func<T, string?>? Prompt { get; set; }

    [Parameter, EditorRequired]
    public EventCallback<T> OnSubmit { get; set; }

    [Parameter]
    public required RenderFragment? ChildContent { get; set; }

    private Modal2 modal = default!;
    private T? Item { get; set; }

    [Display(Name = "Prompt")]
    private string promptResponse { get; set; } = string.Empty;

    public async Task Open(T itemToDelete)
    {
        Item = itemToDelete;
        promptResponse = string.Empty;
        modal.Open();
    }

    public void Close()
    {
        modal.Close();
    }

    public void Dispose()
    {
        modal.Dispose();
    }

    public void Submit()
    {
        OnSubmit.InvokeAsync(Item);
        Close();
    }
}
