@using System.Linq.Expressions
@typeparam T

<div class="InputMultiSelect @(isMenuOpen ? "active" : "") @(Disabled ? "disabled" : null)">
    <div class="inputbordering">
        <div class="selected">
            <input class="PreventSubmit" @bind="input" @bind:event="oninput" @onkeydown="OnKeyDown" @onclick="OpenMenu" @onfocus="OnFocus" @onblur="OnBlur" />
        </div>
    </div>
    <div class="menu" onmousedown="event.preventDefault()">
        <div class="options">
            @if (!filteredAvailableOptions.Any())
            {
                <div style="padding: 1rem 1rem; opacity: .5;">
                    No options
                </div>
            }
            @foreach (T option in filteredAvailableOptions)
            {
                <div class="option @(Value?.Equals(option) ?? false ? "toggle" : null)" @onclick="() => ToggleOption(option)">
                    @DisplayName(option)
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public required T? Value
    {
        get;
        set
        {
            field = value;
            input = value is not null ? DisplayName(value) : "";
            if (!isFocused || string.IsNullOrEmpty(internalSearch))
            {
                internalSearch = string.Empty;
            }
        }
    } // selected options

    [Parameter]
    public EventCallback<T> ValueChanged { get; set; }

    [Parameter, EditorRequired]
    public required IEnumerable<T>? Options { get; set; } // total options

    [Parameter, EditorRequired]
    public required Func<T, string> DisplayName { get; set; }

    [Parameter, EditorRequired]
    public required bool ValueCanBeNull { get; set; }

    [Parameter]
    public Func<string, T>? CreateNew { get; set; }

    [Parameter]
    public required Func<T, T?, bool>? IsEqual { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    public bool HasData => Value is not null || !string.IsNullOrEmpty(input);

    private string input
    {
        get;
        set
        {
            field = value;
            internalSearch = value;
            // ValueChanged.InvokeAsync(Value).Wait();
        }
    } = string.Empty;
    private string internalSearch { get; set; } = string.Empty;
    private bool isMenuOpen;
    private IEnumerable<T> filteredAvailableOptions => (Options ?? []).Where(option => DisplayName(option).Contains(internalSearch, StringComparison.InvariantCultureIgnoreCase));
    private bool isFocused;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            if (isMenuOpen)
            {
                if (CreateNew is not null && !string.IsNullOrWhiteSpace(input))
                {
                    await ToggleOption(CreateNew(input));
                }
                else
                {
                    T? option = filteredAvailableOptions.FirstOrDefault();
                    if (option is not null)
                    {
                        await ToggleOption(option);
                    }
                }
            }
            else
            {
                isMenuOpen = true;
            }
        }
        if (e.Code == "Backspace" && string.IsNullOrEmpty(input))
        {
            if (ValueCanBeNull)
            {
                await ToggleOption(default);
            }
        }
		if (e.Key is "﻿ArrowDown" or ﻿"ArrowUp")
		{

		}
    }

    private async Task ToggleOption(T? optionValue)
    {
        var tempInput = internalSearch;
        isMenuOpen = false;
        await ValueChanged.InvokeAsync(optionValue);
        internalSearch = tempInput;
    }

    private void OpenMenu()
    {
        internalSearch = "";
        isMenuOpen = true;
    }

    private void OnBlur()
    {
        var tempInput = internalSearch;
        input = Value is not null ? DisplayName(Value) : string.Empty;
        internalSearch = tempInput;
        isFocused = false;
        isMenuOpen = false;
    }

    private void OnFocus()
    {
        internalSearch = "";
        isFocused = true;
    }
}
