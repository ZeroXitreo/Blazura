@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime

@foreach (var drawer in registeredDrawers)
{
    <div class="DrawerBackdrop @(drawer.IsOpen ? "opened" : "closed")" @onclick="() => drawer.Close()"></div>
    <div class="Drawer @(drawer.IsOpen ? "opened" : "closed")">
        @drawer.ChildContent
    </div>
}

@code {
    [CascadingParameter] private Backdrop backdrop { get; set; } = default!;

    private HashSet<Drawer> registeredDrawers = [];

    internal void Register(Drawer drawer)
    {
        registeredDrawers.Add(drawer);
    }

    internal void Unregister(Drawer drawer)
    {
        registeredDrawers.Remove(drawer);
        StateHasChanged();
        RunBackdropCheck();
    }

    internal async Task TriggerRender()
    {
        await InvokeAsync(StateHasChanged);
    }

    internal void RunBackdropCheck()
    {
        backdrop.SetBackdrop(this.GetType(), registeredDrawers.Any(d => d.IsOpen));
    }
}
