@inherits LayoutComponentBase


<CascadingValue Value="backdrop">
    <CascadingValue Value="lightbox">
        <CascadingValue Value="dialogManager">
            <CascadingValue Value="contextMenuManager">
                <CascadingValue Value="gaSnackbar">
                    @Body
                </CascadingValue>
                <Snackbar @ref="gaSnackbar" />
            </CascadingValue>
            <ContextMenuManager @ref="contextMenuManager" />
        </CascadingValue>
        <DialogManager @ref="dialogManager" />
    </CascadingValue>
    <Lightbox @ref="lightbox" />
</CascadingValue>
<Backdrop @ref="backdrop" />


@code {
    public Backdrop backdrop { get; set; } = default!;
    public Lightbox lightbox { get; set; } = default!;
    public DialogManager dialogManager { get; set; } = default!;
    public ContextMenuManager contextMenuManager { get; set; } = default!;
    public Snackbar gaSnackbar { get; set; } = default!;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            StateHasChanged();
        }
    }
}
