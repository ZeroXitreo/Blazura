<div class="HStack @(Sizing.ToString()) @(HeightAlignment.ToString())">
	@ChildContent
</div>

@code {
	[Parameter]
	public RenderFragment? ChildContent { get; set; }

	[Parameter]
	public Sizing Sizing { get; set; } = Sizing.Md;

	[Parameter]
	public HeightAlignment HeightAlignment { get; set; } = HeightAlignment.Stretch;
}
